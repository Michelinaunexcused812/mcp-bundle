{
  "manifest_version": "0.3",
  "name": "undefined-ref-server",
  "version": "1.0.0",
  "description": "Server with undefined config reference",
  "author": {
    "name": "Test"
  },
  "server": {
    "type": "node",
    "entry_point": "server/index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/server/index.js"],
      "env": {
        "SECRET": "${user_config.nonexistent_key}"
      }
    }
  }
}
