{
  "manifest_version": "0.3",
  "name": "my-binary-server",
  "display_name": "My Binary MCP Server",
  "version": "1.0.0",
  "description": "A compiled binary MCP server",
  "author": {
    "name": "Test Author"
  },
  "server": {
    "type": "binary",
    "entry_point": "server/my-server",
    "mcp_config": {
      "command": "${__dirname}/server/my-server",
      "args": [],
      "platform_overrides": {
        "win32": {
          "command": "${__dirname}/server/my-server.exe"
        }
      }
    }
  },
  "tools": [
    {
      "name": "execute",
      "description": "Execute a command"
    }
  ],
  "keywords": ["binary", "mcp"],
  "license": "MIT",
  "compatibility": {
    "platforms": ["darwin", "win32", "linux"]
  }
}
